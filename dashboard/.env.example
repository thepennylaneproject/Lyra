# LYRA Dashboard
# Copy to .env.local

LYRA_DASHBOARD_DATA_DIR=./data
LYRA_AUDIT_DIR=../audits

# Supabase Postgres — required for production (projects + orchestration jobs)
# Apply supabase/migrations/20250318120000_lyra_core.sql
# Use the Session Pooler URL from Supabase → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
# Session pooler limits total clients; dashboard uses one shared pool (default max 5). Raise only if needed.
# PG_POOL_MAX=5

# Supabase JS client — used for constraint audit storage (lyra_constraint_audits table).
# Get these from Supabase → Project Settings → API → Project URL / anon key.
# The anon key is intentionally client-side (NEXT_PUBLIC_): Supabase RLS controls what
# the anon role can read/write. Verify RLS policies on lyra_constraint_* tables before
# deploying to production.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API auth — set a long random string to protect all /api/* routes in production.
# Use ORCHESTRATION_ENQUEUE_SECRET for both the Netlify cron function and dashboard
# auth. DASHBOARD_API_SECRET is an optional override if you want to use a separate
# secret for the dashboard UI (takes priority when set).
ORCHESTRATION_ENQUEUE_SECRET=
# DASHBOARD_API_SECRET=   # optional override; if set, takes priority over ORCHESTRATION_ENQUEUE_SECRET

# Optional: set to 1 to allow unauthenticated /api/* access (local dev without a secret).
# Never set this in production.
# LYRA_ALLOW_OPEN_API=1

# Optional: BullMQ — worker picks up jobs immediately
REDIS_URL=

LYRA_POSTGRES_SCHEMA=public
LYRA_POSTGRES_EVENTS_TABLE=lyra_orchestration_events
LYRA_POSTGRES_SNAPSHOTS_TABLE=lyra_project_snapshots

# Personal API key (Linear → Settings → API). No "Bearer " prefix in env.
LINEAR_API_KEY=
# Team UUID from Linear → Settings → API, or team key (e.g. ENG)
LINEAR_TEAM_ID=
LINEAR_LABEL_ID=
LINEAR_PROJECT_ID=

LYRA_ROUTING_CONFIG=audits/routing_config.json
LYRA_ROUTING_STRATEGY=balanced
LYRA_AIMLAPI_NANO_MODEL=meta-llama/3.1-8b-instruct
LYRA_OPENAI_MINI_MODEL=gpt-4o-mini
LYRA_OPENAI_BALANCED_MODEL=gpt-4o

# Optional: Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://[KEY]@o[ORG].ingest.sentry.io/[PROJECT_ID]
# SENTRY_DSN=https://[KEY]@o[ORG].ingest.sentry.io/[PROJECT_ID]
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=lyra-dashboard
# SENTRY_AUTH_TOKEN=   # required for source map uploads in CI

# Optional: public URL for audit workflow documentation
# NEXT_PUBLIC_LYRA_WORKFLOWS_DOC_URL=
