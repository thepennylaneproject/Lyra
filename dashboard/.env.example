# LYRA Dashboard
# Copy this file to .env.local and fill in the values you need.

# Local data path (optional)
LYRA_DASHBOARD_DATA_DIR=./data

# Path to the Lyra audit output directory (relative to this dashboard folder, or absolute).
# Used by the engine sync API to read open_findings.json, repair_queue.json, etc.
LYRA_AUDIT_DIR=../audits

# Linear integration (optional; required only for push/pull sync)
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_LABEL_ID=
LINEAR_PROJECT_ID=

# Routing strategy + model overrides
LYRA_ROUTING_CONFIG=audits/routing_config.json
LYRA_ROUTING_STRATEGY=balanced
LYRA_ROUTING_MAX_COST_PER_TASK=
LYRA_ROUTING_CONFIDENCE_THRESHOLD=
LYRA_ROUTING_AUTO_ESCALATE=
LYRA_ROUTING_MAX_RETRIES=

LYRA_AIMLAPI_NANO_MODEL=meta-llama/3.1-8b-instruct
LYRA_AIMLAPI_CHEAP_MODEL=mistralai/mistral-7b-instruct
LYRA_AIMLAPI_MID_MODEL=mistralai/mixtral-8x7b-instruct
LYRA_AIMLAPI_EXPENSIVE_MODEL=meta-llama/3.1-70b-instruct
LYRA_HF_NANO_MODEL=HuggingFaceH4/zephyr-7b-beta
LYRA_OPENAI_MINI_MODEL=gpt-4o-mini
LYRA_OPENAI_BALANCED_MODEL=gpt-4o
LYRA_ANTHROPIC_HAIKU_MODEL=claude-3-haiku
LYRA_ANTHROPIC_SONNET_MODEL=claude-3.5-sonnet
LYRA_ANTHROPIC_OPUS_MODEL=claude-3-opus
LYRA_GEMINI_FLASH_MODEL=gemini-1.5-flash
LYRA_GEMINI_PRO_MODEL=gemini-1.5-pro

# GitHub-backed project storage and control plane
LYRA_GITHUB_OWNER=
LYRA_GITHUB_REPO=
LYRA_GITHUB_TOKEN=
LYRA_GITHUB_WORKFLOW=scheduled-audit.yml

# Durable state ledger (optional; stores orchestration events and project snapshots)
LYRA_SUPABASE_URL=
LYRA_SUPABASE_SERVICE_ROLE_KEY=
LYRA_SUPABASE_SCHEMA=public
LYRA_SUPABASE_EVENTS_TABLE=lyra_orchestration_events
LYRA_SUPABASE_SNAPSHOTS_TABLE=lyra_project_snapshots
