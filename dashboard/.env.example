# LYRA Dashboard – local dev
# Copy to .env.local and fill in if using Linear sync.

# Optional: Linear integration (push/pull findings)
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=your-team-uuid
# LINEAR_LABEL_ID=your-label-uuid
# LINEAR_PROJECT_ID=

# Local data path (default: ./data under the dashboard app directory)
# LYRA_DASHBOARD_DATA_DIR=./data
