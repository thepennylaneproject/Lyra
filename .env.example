# Lyra Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM Provider API Keys
# ============================================================================
# At least one of these should be set for the worker to run audits

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# LLM Routing Configuration
# ============================================================================

# Routing strategy: aggressive (cheapest), balanced (default), precision (best)
LYRA_ROUTING_STRATEGY=balanced

# Explicit model selection (optional, overrides strategy)
# Format: "provider:model" or model name that will be inferred
# Examples:
#   - openai:mini (GPT-4o mini)
#   - openai:balanced (GPT-4o)
#   - anthropic:haiku (Claude 3.5 Haiku)
#   - anthropic:sonnet (Claude 3.5 Sonnet)
#   - anthropic:opus (Claude 3 Opus)
# LYRA_AUDIT_MODEL=openai:mini

# ============================================================================
# Database Configuration
# ============================================================================

# Primary database URL (Supabase or self-hosted Postgres)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://lyra:lyra-dev-password@localhost:5432/lyra

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis URL for job queue (optional, falls back to DB polling)
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ============================================================================
# Authentication
# ============================================================================

# Shared secret for dashboard API (min 32 characters recommended)
# Used for API authentication and session signing
DASHBOARD_API_SECRET=your-dashboard-api-secret-here

# ============================================================================
# Dashboard Configuration
# ============================================================================

# Base URL of the dashboard (used by repair engine for callbacks)
LYRA_DASHBOARD_URL=http://localhost:3000

# API key for dashboard integration
LYRA_DASHBOARD_API_KEY=your-dashboard-api-key-here

# ============================================================================
# Worker Configuration
# ============================================================================

# Repository root directory (where code to audit is)
LYRA_REPO_ROOT=/workspace

# Job polling interval (milliseconds)
LYRA_JOB_POLL_MS=5000

# Idle polling interval when no jobs available
LYRA_JOB_POLL_IDLE_MS=10000

# Max files to sample per audit pass
LYRA_MAX_FILES_PER_PASS=8

# Max characters to read from each file
LYRA_MAX_CHARS_PER_FILE=8000

# ============================================================================
# Error Tracking (Optional)
# ============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/
# SENTRY_DSN=

# ============================================================================
# Deployment Configuration
# ============================================================================

# Public URL of the deployed dashboard (for CORS, etc)
# NEXT_PUBLIC_DEPLOY_URL=https://lyra.example.com

# ============================================================================
# Debugging
# ============================================================================

# Debug output (comma-separated namespaces)
# Examples: "lyra:*" (all), "lyra:worker:*", "lyra:db:*"
# DEBUG=lyra:*

# Log level: debug, info, warn, error
# LOG_LEVEL=info
