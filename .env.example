# =========================
# Existing Lyra integrations
# =========================

LINEAR_API_KEY=lin_api_your_key_here
LINEAR_TEAM_ID=your-team-uuid
LINEAR_LABEL_ID=your-label-uuid
LINEAR_PROJECT_ID=

CURSOR_API_KEY=crsr_your_key_here

# =========================
# Batch fixer (existing)
# =========================

ANTHROPIC_API_KEY=sk-ant-your_key_here

# =========================
# Multi-provider routing
# =========================
# Lyra routes tasks across providers by cost tier.
# Configure only the providers you have keys for — unconfigured providers are skipped.
# See audits/routing_config.json to customize task → provider routing.

# aimlapi.com — unified gateway for open-source models (Llama, Qwen, Mistral, etc.)
# Provides cheap, mid, and expensive tiers. Recommended primary provider.
# Get your key at: https://aimlapi.com
AIMLAPI_API_KEY=

# HuggingFace — free serverless inference for nano-tier (trivial tasks)
# Optional: leave empty to use public endpoints (rate-limited, no auth required)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenAI — direct API for structured outputs and tool-calling reliability
OPENAI_API_KEY=

# Google Gemini — fast, cheap inference for high-volume batch processing
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =========================
# Model overrides (optional)
# =========================
# Override the default model for any provider tier.
# Leave blank to use the built-in defaults.

# aimlapi tier models
LYRA_AIMLAPI_NANO_MODEL=
LYRA_AIMLAPI_CHEAP_MODEL=
LYRA_AIMLAPI_MID_MODEL=
LYRA_AIMLAPI_EXPENSIVE_MODEL=

# HuggingFace nano model
LYRA_HF_NANO_MODEL=

# OpenAI tier models
LYRA_OPENAI_MINI_MODEL=
LYRA_OPENAI_BALANCED_MODEL=

# Anthropic tier models (ANTHROPIC_API_KEY reused from batch fixer section above)
LYRA_ANTHROPIC_HAIKU_MODEL=
LYRA_ANTHROPIC_SONNET_MODEL=
LYRA_ANTHROPIC_OPUS_MODEL=

# Gemini tier models
LYRA_GEMINI_FLASH_MODEL=
LYRA_GEMINI_PRO_MODEL=

# Path to custom routing config JSON (defaults to audits/routing_config.json)
LYRA_ROUTING_CONFIG=audits/routing_config.json

# =========================
# Patch-tree repair engine
# =========================

# Optional auth if your vLLM endpoint requires bearer auth
LYRA_LLM_API_KEY=

# Search settings
LYRA_ROOT_BRANCHING_FACTOR=5
LYRA_BEAM_WIDTH=2
LYRA_MAX_DEPTH=2
LYRA_MAX_EVALS_PER_FINDING=20
LYRA_MIN_EXPAND_SCORE=0.65

# Evaluation settings
LYRA_EVAL_USE_DOCKER=true
LYRA_DOCKER_IMAGE=python:3.11
LYRA_LINT_COMMAND=
LYRA_TYPECHECK_COMMAND=
LYRA_TEST_COMMAND=python3 -m unittest
LYRA_EVAL_TIMEOUT_SECONDS=300

# Integrations
LYRA_VLLM_BASE_URL=http://localhost:8000
LYRA_VLLM_MODEL=deepseek-ai/deepseek-coder-6.7b-instruct
LYRA_FALLBACK_MODEL=
# Optional cross-provider fallback endpoint/key (defaults to primary endpoint/key when empty)
LYRA_FALLBACK_BASE_URL=
LYRA_FALLBACK_API_KEY=
LYRA_REDIS_URL=redis://localhost:6379/0
LYRA_QDRANT_URL=http://localhost:6333
LYRA_QDRANT_COLLECTION=lyra_patch_memory

# Apply + artifact controls
LYRA_AUTO_APPLY=true
LYRA_DRY_RUN=true
LYRA_MAX_FILES_CHANGED=8
LYRA_REPAIR_RUNS_DIR=audits/repair_runs
LYRA_FINDINGS_FILE=audits/open_findings.json
LYRA_INDEX_FILE=audits/index.json

